# Club No.8 遊戲服務環境變數範例
# 複製為 .env 或在 Makefile/CI 中用 set -a && source ... && set +a 載入

# 本機 dev 時由 Consul resolver 撥號 tx / record。
CONSUL_ADDR=127.0.0.1:8500
ETCD_ENDPOINTS=127.0.0.1:2379

# gRPC listen port（本遊戲自己）。預設 9201；多遊戲同機時避免衝突。
GRPC_PORT=9201

# Consul 向下游送的 health check 地址；docker-compose 容器內連 host 需用 LAN IP。
ADVERTISE_HOST=127.0.0.1

# 依賴服務名（在 Consul 中的 service name）
TX_SERVICE_NAME=tx
RECORD_SERVICE_NAME=record

# 環境別（影響 Consul tag）
ENV=dev
